# Copy this file to .env.local and fill in the values.

# Base URL of the Laravel 11 backend (no trailing slash, no /api/v1 suffix).
# The /api/v1 prefix is appended automatically by lib/api.ts.
# Leave empty to keep using mock/demo data (works without a backend).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
